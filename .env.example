# NestJS API base (include /api/v1). Defaults in code to http://localhost:3000/api/v1
VITE_API_URL=http://localhost:3000/api/v1

# Show demo email/password on login screens (super admin + facility). On by default in `npm run dev`.
# VITE_SHOW_DEMO_LOGIN_HINT=true

# When the API implements GET /api/v1/admin/subscriptions/:id, set:
# VITE_USE_SUBSCRIPTION_API=true
